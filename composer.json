{
    "name": "laravel-zoho/mcp-server",
    "description": "Laravel package that runs a Model Context Protocol (MCP) server exposing Zoho REST API operations as MCP tools (via Laravel MCP).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "mcp",
        "model-context-protocol",
        "zoho",
        "zoho-crm",
        "oauth"
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/auth": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "laravel/mcp": "^0.7"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.5.50|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelZohoMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelZohoMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelZohoMcp\\ZohoMcpServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
